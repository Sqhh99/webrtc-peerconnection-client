import { LogsPanel } from "logs-panel.slint";
import { SidebarPanel } from "sidebar-panel.slint";
import { VideoStage } from "video-stage.slint";
import { IncomingCallOverlay } from "incoming-call-overlay.slint";
import { MessageDialogOverlay } from "message-dialog-overlay.slint";

export component AppWindow inherits Window {
    in-out property <bool> connected: false;
    in-out property <string> signal_url: "";
    in-out property <string> username: "";
    in-out property <string> client_id: "";
    in-out property <string> selected_peer_id: "";
    in-out property <string> current_peer_id: "";
    in-out property <string> connection_status_text: "Disconnected";
    in-out property <string> connection_button_text: "Reconnect";
    in-out property <string> logs_button_text: "Show Logs";
    in-out property <bool> logs_visible: false;
    in-out property <string> call_state_text: "Idle";
    in-out property <string> peer_text: "(none)";
    in-out property <bool> can_start_call: false;
    in-out property <bool> can_hang_up: false;
    in-out property <string> media_mode_text: "Camera";
    in-out property <string> media_detail_text: "Camera";
    in-out property <string> stats_text: "";
    in-out property <[string]> clients: [];
    in-out property <string> logs_text: "";
    in-out property <bool> incoming_visible: false;
    in-out property <string> incoming_caller_id: "";
    in-out property <bool> dialog_visible: false;
    in-out property <string> dialog_kind: "Info";
    in-out property <string> dialog_title: "";
    in-out property <string> dialog_message: "";
    in-out property <bool> remote_video_visible: false;
    in-out property <bool> local_video_visible: false;
    in-out property <image> remote_video_image;
    in-out property <image> local_video_image;

    property <length> sidebar_width: 250px;
    property <length> local_preview_card_width: 240px;
    property <length> local_preview_card_height: 135px;

    callback toggle_logs();
    callback connect_or_disconnect();
    callback select_peer(string);
    callback start_call();
    callback hang_up();
    callback use_camera();
    callback open_media_file();
    callback accept_incoming();
    callback reject_incoming();
    callback dismiss_dialog();

    title: "PeerConnection Client";
    width: 1440px;
    height: 900px;
    background: #090e17;

    HorizontalLayout {
        SidebarPanel {
            width: root.sidebar_width;
            connected: root.connected;
            signal_url: root.signal_url;
            username: root.username;
            connection_status_text: root.connection_status_text;
            connection_button_text: root.connection_button_text;
            logs_button_text: root.logs_button_text;
            selected_peer_id: root.selected_peer_id;
            call_state_text: root.call_state_text;
            peer_text: root.peer_text;
            can_start_call: root.can_start_call;
            can_hang_up: root.can_hang_up;
            media_mode_text: root.media_mode_text;
            media_detail_text: root.media_detail_text;
            stats_text: root.stats_text;
            clients: root.clients;
            toggle_logs => { root.toggle_logs(); }
            connect_or_disconnect => { root.connect_or_disconnect(); }
            select_peer(client) => { root.select_peer(client); }
            start_call => { root.start_call(); }
            hang_up => { root.hang_up(); }
            use_camera => { root.use_camera(); }
            open_media_file => { root.open_media_file(); }
        }

        Rectangle {
            width: 8px;
            background: transparent;
            z: 10;

            Rectangle {
                width: 1px;
                height: parent.height;
                x: 3px;
                background: splitter_touch.has-hover ? #60a5fa : #1e293b;
            }

            splitter_touch := TouchArea {
                mouse-cursor: ew-resize;
                moved => {
                    root.sidebar_width = Math.max(220px, Math.min(800px, root.sidebar_width + (self.mouse-x - (self.width / 2))));
                }
            }
        }

        HorizontalLayout {
            horizontal-stretch: 1;

            VideoStage {
                horizontal-stretch: 1;
                remote_video_visible: root.remote_video_visible;
                local_video_visible: root.local_video_visible;
                remote_video_image: root.remote_video_image;
                local_video_image: root.local_video_image;
                local_preview_card_width: root.local_preview_card_width;
                local_preview_card_height: root.local_preview_card_height;
            }

            if logs_visible : LogsPanel {
                logs_text: root.logs_text;
            }
        }
    }

    if incoming_visible : IncomingCallOverlay {
        width: parent.width;
        height: parent.height;
        caller_id: root.incoming_caller_id;
        accept => { root.accept_incoming(); }
        reject => { root.reject_incoming(); }
    }

    if dialog_visible : MessageDialogOverlay {
        width: parent.width;
        height: parent.height;
        dialog_kind: root.dialog_kind;
        dialog_title: root.dialog_title;
        dialog_message: root.dialog_message;
        dismiss => { root.dismiss_dialog(); }
    }
}
