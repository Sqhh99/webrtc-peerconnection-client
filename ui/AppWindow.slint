import { Button, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    in-out property <bool> connected: false;
    in-out property <string> signal_url: "";
    in-out property <string> username: "";
    in-out property <string> client_id: "";
    in-out property <string> selected_peer_id: "";
    in-out property <string> current_peer_id: "";
    in-out property <string> connection_status_text: "Disconnected";
    in-out property <string> connection_button_text: "Reconnect";
    in-out property <string> logs_button_text: "Show Logs";
    in-out property <bool> logs_visible: false;
    in-out property <string> call_state_text: "Idle";
    in-out property <string> peer_text: "(none)";
    in-out property <bool> can_start_call: false;
    in-out property <bool> can_hang_up: false;
    in-out property <string> media_mode_text: "Camera";
    in-out property <string> media_detail_text: "Camera";
    in-out property <string> stats_text: "";
    in-out property <[string]> clients: [];
    in-out property <string> logs_text: "";
    in-out property <bool> incoming_visible: false;
    in-out property <string> incoming_caller_id: "";
    in-out property <bool> dialog_visible: false;
    in-out property <string> dialog_kind: "Info";
    in-out property <string> dialog_title: "";
    in-out property <string> dialog_message: "";
    in-out property <bool> remote_video_visible: false;
    in-out property <bool> local_video_visible: false;
    in-out property <image> remote_video_image;
    in-out property <image> local_video_image;

    property <length> sidebar_width: 250px;
    property <length> local_preview_card_width: 240px;
    property <length> local_preview_card_height: 135px;

    callback toggle_logs();
    callback connect_or_disconnect();
    callback select_peer(string);
    callback start_call();
    callback hang_up();
    callback use_camera();
    callback open_media_file();
    callback accept_incoming();
    callback reject_incoming();
    callback dismiss_dialog();

    title: "PeerConnection Client";
    width: 1440px;
    height: 900px;
    background: #090e17;

    HorizontalLayout {
        // --- 1. LEFT SIDEBAR ---
        Rectangle {
            width: root.sidebar_width;
            background: #0b111a;
            
            // REMOVED OUTER SCROLLVIEW: Now the structure directly drives vertical stretching!
            VerticalLayout {
                padding: 12px;
                spacing: 16px;

                // === UPPER FIXED SECTIONS ===
                VerticalLayout {
                    spacing: 8px;
                    vertical-stretch: 0;

                    // HEADER
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "PeerConnection"; color: #f8fafc; font-size: 16px; font-weight: 700; }
                        Text { text: signal_url; color: #475569; font-size: 10px; wrap: word-wrap; }
                    }
                    
                    // Merged User and Status to one line
                    HorizontalLayout {
                        spacing: 4px;
                        Text { text: "User:"; color: #64748b; font-size: 11px; }
                        Text { text: username; color: #e2e8f0; font-size: 11px; font-weight: 600; horizontal-stretch: 1; }
                        Text { text: "Status:"; color: #64748b; font-size: 11px; }
                        Text { text: connection_status_text; color: connected ? #34d399 : #fb923c; font-size: 11px; font-weight: 600; }
                    }
                    
                    HorizontalLayout {
                        spacing: 6px;
                        height: 28px; // Force extreme compactness on buttons
                        Button { text: connection_button_text; clicked => { root.connect_or_disconnect(); } horizontal-stretch: 1; }
                        Button { text: logs_button_text; clicked => { root.toggle_logs(); } horizontal-stretch: 1; }
                    }
                }

                // ONLINE USERS
                VerticalLayout {
                    spacing: 4px;
                    vertical-stretch: 0;
                    Text { text: "ONLINE USERS"; color: #475569; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    
                    for client in clients : Rectangle {
                        height: 24px; // Tinier items
                        border-radius: 4px;
                        background: selected_peer_id == client ? #2563eb1a : (client_touch.has-hover ? #ffffff08 : transparent);

                        Text {
                            x: 8px;
                            y: 5px;
                            text: client;
                            color: selected_peer_id == client ? #60a5fa : #cbd5e1;
                            font-weight: selected_peer_id == client ? 600 : 400;
                            font-size: 12px;
                        }

                        client_touch := TouchArea {
                            clicked => { root.select_peer(client); }
                        }
                    }
                    if clients.length == 0 : Text {
                        text: "No users online";
                        color: #475569;
                        font-size: 11px;
                        padding-left: 2px;
                    }
                }

                // CALL CONTROLS
                VerticalLayout {
                    spacing: 4px;
                    vertical-stretch: 0;
                    // Incorporated peer into title to save a row
                    Text { text: "CALL CONTROLS (" + peer_text + ")"; color: #475569; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    
                    HorizontalLayout {
                        spacing: 6px;
                        height: 28px;
                        Button { text: "Call"; enabled: can_start_call; clicked => { root.start_call(); } horizontal-stretch: 1; }
                        Button { text: "Hang Up"; enabled: can_hang_up; clicked => { root.hang_up(); } horizontal-stretch: 1; }
                    }
                    Text { text: "State: " + call_state_text; color: #cbd5e1; font-size: 11px; padding-left: 2px; }
                }

                // MEDIA SOURCE
                VerticalLayout {
                    spacing: 4px;
                    vertical-stretch: 0;
                    // Incorporated mode into title to save a row
                    Text { text: "MEDIA (" + media_mode_text + ")"; color: #475569; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    Text { text: media_detail_text; color: #94a3b8; font-size: 10px; padding-left: 2px; wrap: word-wrap; }
                    
                    HorizontalLayout {
                        spacing: 6px;
                        height: 28px;
                        Button { text: "Camera"; clicked => { root.use_camera(); } horizontal-stretch: 1; }
                        Button { text: "File..."; clicked => { root.open_media_file(); } horizontal-stretch: 1; }
                    }
                }

                // === RTC STATS : THE STAR OF THIS UPDATE ===
                VerticalLayout {
                    spacing: 4px;
                    vertical-stretch: 1; // It will NOW actively stretch to consume ALL remaining vertical space on the window
                    
                    Text { text: "RTC STATS"; color: #475569; font-size: 10px; font-weight: 700; letter-spacing: 1px; }
                    
                    Rectangle {
                        vertical-stretch: 1; 
                        background: #05080f;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: #1e293b;
                        clip: true;

                        ScrollView {
                            width: parent.width;
                            height: parent.height;

                            VerticalLayout {
                                padding: 8px;
                                Text {
                                    text: stats_text;
                                    color: #4ade80; 
                                    font-size: 11px;
                                    font-family: "Consolas";
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }
            }
        }

        // --- 2. SPLITTER ---
        Rectangle {
            width: 8px;
            background: transparent;
            z: 10;
            
            Rectangle {
                width: 1px;
                height: parent.height;
                x: 3px;
                background: splitter_touch.has-hover ? #60a5fa : #1e293b;
            }

            splitter_touch := TouchArea {
                mouse-cursor: ew-resize;
                moved => {
                    root.sidebar_width = Math.max(220px, Math.min(800px, root.sidebar_width + (self.mouse-x - (self.width / 2))));
                }
            }
        }

        // --- 3. MAIN VIDEO AREA ---
        HorizontalLayout {
            horizontal-stretch: 1;
            
            Rectangle {
                background: #000000;
                clip: true;
                horizontal-stretch: 1;

                if !remote_video_visible : VerticalLayout {
                    alignment: center;
                    Text {
                        text: "Waiting for video stream...";
                        color: #334155;
                        font-size: 16px;
                        horizontal-alignment: center;
                    }
                }

                if remote_video_visible : Image {
                    width: parent.width;
                    height: parent.height;
                    source: remote_video_image;
                    image-fit: contain;
                }

                if local_video_visible : Rectangle {
                    width: local_preview_card_width;
                    height: local_preview_card_height;
                    x: parent.width - self.width - 24px;
                    y: parent.height - self.height - 24px;
                    background: #090e17;
                    border-radius: 8px;
                    drop-shadow-blur: 24px;
                    drop-shadow-color: #000000a0;
                    drop-shadow-offset-y: 12px;

                    border-width: 1px;
                    border-color: #1e293b;

                    Image {
                        width: parent.width;
                        height: parent.height;
                        source: local_video_image;
                        image-fit: contain;
                    }
                }
            }

            // --- 4. LOGS SIDEBAR (OPTIONAL) ---
            if logs_visible : Rectangle {
                width: 380px;
                background: #0b111a;

                // Border separator
                Rectangle {
                    width: 1px;
                    height: parent.height;
                    x: 0;
                    background: #1e293b;
                }

                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;
                    x: 1px;
                    width: parent.width - 1px;

                    Text {
                        text: "SYSTEM LOGS";
                        color: #64748b;
                        font-size: 12px;
                        font-weight: 700;
                        letter-spacing: 1px;
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        background: #05080f;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #1e293b;
                        clip: true;

                        ScrollView {
                            width: parent.width;
                            height: parent.height;

                            VerticalLayout {
                                padding: 12px;
                                Text {
                                    text: logs_text;
                                    color: #cbd5e1;
                                    font-family: "Consolas";
                                    font-size: 11px;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // --- OVERLAYS ---
    if incoming_visible : Rectangle {
        width: parent.width;
        height: parent.height;
        background: #00000099;
        z: 100;

        Rectangle {
            width: 400px;
            height: 180px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #0f172a;
            border-radius: 16px;
            border-width: 1px;
            border-color: #334155;
            drop-shadow-blur: 32px;
            drop-shadow-color: #00000099;
            drop-shadow-offset-y: 12px;

            VerticalLayout {
                padding: 24px;
                spacing: 16px;
                alignment: center;

                Text {
                    text: "Incoming Call";
                    color: #f8fafc;
                    font-size: 20px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                Text {
                    text: incoming_caller_id + " is calling you...";
                    color: #cbd5e1;
                    font-size: 15px;
                    horizontal-alignment: center;
                }

                HorizontalLayout {
                    spacing: 16px;
                    alignment: end;
                    Button {
                        text: "Decline";
                        clicked => { root.reject_incoming(); }
                    }
                    Button {
                        text: "Accept";
                        clicked => { root.accept_incoming(); }
                    }
                }
            }
        }
    }

    if dialog_visible : Rectangle {
        width: parent.width;
        height: parent.height;
        background: #00000099;
        z: 100;

        Rectangle {
            width: 440px;
            height: 220px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: dialog_kind == "Error" ? #2a0e12 : #0f172a;
            border-radius: 16px;
            border-width: 1px;
            border-color: dialog_kind == "Error" ? #7f1d1d : #334155;
            drop-shadow-blur: 32px;
            drop-shadow-color: dialog_kind == "Error" ? #7f1d1d60 : #00000099;
            drop-shadow-offset-y: 12px;

            VerticalLayout {
                padding: 24px;
                spacing: 16px;

                Text {
                    text: dialog_title;
                    color: dialog_kind == "Error" ? #fca5a5 : #f8fafc;
                    font-size: 20px;
                    font-weight: 700;
                }
                ScrollView {
                    vertical-stretch: 1;
                    Text {
                        text: dialog_message;
                        color: #e2e8f0;
                        font-size: 14px;
                        wrap: word-wrap;
                    }
                }
                HorizontalLayout {
                    alignment: end;
                    Button {
                        text: "Dismiss";
                        clicked => { root.dismiss_dialog(); }
                    }
                }
            }
        }
    }
}
